---
/**
 * PROFESSIONAL LOGO COMPONENT
 * Focused on a clean, transparent, high-visibility design.
 */
import { Ship } from 'lucide-react';
import { sanityClient } from 'sanity:client';

interface Props {
  // Option for using the logo on Light (Header) vs Dark (Footer) backgrounds.
  variant?: 'light' | 'dark';
}

const { variant = 'light' } = Astro.props;

const settings = await sanityClient.fetch(`*[_id == "siteSettings"][0]`);
const brandName = settings?.businessName || 'Cargo to Pakistan';

// Logic to switch ONLY the component colors based on the variant
const iconColor = variant === 'light' ? 'text-slate-900' : 'text-white';

const textMainColor = variant === 'light' ? 'text-slate-900' : 'text-white';
---

<div class="flex items-center gap-2 group cursor-pointer select-none">
  <div
    class="p-1 md:p-1.5 transition-transform duration-300 group-hover:scale-110 group-hover:rotate-3"
  >
    <Ship class:list={['w-5 h-5 md:w-6 md:h-6', iconColor]} strokeWidth={2.5} />
  </div>

  <span class:list={['text-2xl font-black tracking-tight', textMainColor]}>
    {brandName}
  </span>
</div>

<style>
  /* Ensure the brand name stays together on one line on small screens */
  span {
    white-space: nowrap;
  }
</style>

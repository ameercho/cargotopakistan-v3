---
import { sanityClient } from 'sanity:client';
import { Phone, MessageSquare, ChevronDown, Menu, X } from 'lucide-react';
import Logo from './Logo.astro';

// Fetching Global Settings including our new Header Menu
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{
  ...,
  headerMenu[]
}`);

// Fetching Services for the dropdown
const services = (await sanityClient.fetch(`*[_type == "service"] | order(order asc)`)) || [];

// Safety check for navLinks
const navLinks = settings?.headerMenu || [];
---

<header class="sticky top-0 z-[100] bg-white border-b border-slate-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="hover:opacity-90 transition-opacity w-32 md:w-auto">
      <Logo />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class="font-semibold text-slate-600 hover:text-blue-600 transition-colors"
          >
            {item.label}
          </a>
        ))
      }

      <div class="relative group py-4">
        <button
          class="font-semibold text-slate-600 group-hover:text-blue-600 flex items-center gap-1"
        >
          Services
          <ChevronDown size={14} />
        </button>

        <div
          class="absolute top-full -left-4 w-60 bg-white border border-slate-100 shadow-xl rounded-xl p-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all"
        >
          {
            services.map((s) => (
              <a
                href={`/services/${s.slug.current}`}
                class="block px-4 py-2 hover:bg-blue-50 rounded-lg font-medium text-slate-700 transition-colors"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      <a
        href={`tel:${settings?.phone}`}
        class="hidden md:flex items-center justify-center text-blue-600 hover:text-blue-700 transition-colors"
        aria-label="Call Us"
      >
        <Phone size={20} />
        <span class="ml-2 font-bold text-slate-900">{settings?.phone}</span>
      </a>

      <a
        href={`https://wa.me/${settings?.whatsappNumber}`}
        class="hidden md:flex items-center justify-center px-6 py-2.5 rounded-lg bg-green-600 text-white hover:bg-green-700 transition-colors shadow-lg shadow-green-100"
        aria-label="Chat on WhatsApp"
      >
        <MessageSquare size={20} />
        <span class="ml-2 font-bold">WhatsApp</span>
      </a>

      <button
        class="md:hidden p-2 text-slate-600 relative z-[110] flex items-center justify-center"
        id="mobile-menu-button"
        aria-label="Toggle Menu"
        data-state="closed"
      >
        <div id="hamburger-icon">
          <Menu size={28} />
        </div>
        <div id="close-icon" class="hidden">
          <X size={28} />
        </div>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white z-[105] translate-x-full transition-transform duration-300 md:hidden pt-24 px-6 overflow-y-auto"
  >
    <nav class="flex flex-col gap-4">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class="text-2xl font-bold text-slate-900 border-b border-slate-50 pb-4"
          >
            {item.label}
          </a>
        ))
      }

      <div class="border-b border-slate-50 pb-4">
        <button
          id="mobile-services-toggle"
          class="flex items-center justify-between w-full text-2xl font-bold text-slate-900 text-left"
        >
          Services
          <ChevronDown id="services-chevron" class="transition-transform duration-300" size={24} />
        </button>

        <div id="mobile-services-list" class="hidden flex-col gap-4 mt-4 pl-4 overflow-hidden">
          {
            services.map((s) => (
              <a
                href={`/services/${s.slug.current}`}
                class="text-lg font-semibold text-slate-600 border-l-2 border-blue-100 pl-4 py-1"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>

      <div class="mt-4 flex flex-col gap-6">
        <a
          href={`tel:${settings?.phone}`}
          class="flex items-center gap-3 text-lg font-bold text-slate-900"
        >
          <Phone class="text-blue-600" />
          {settings?.phone}
        </a>
        <a
          href={`https://wa.me/${settings?.whatsappNumber}`}
          class="flex items-center gap-3 text-lg font-bold text-green-600"
        >
          <MessageSquare /> WhatsApp
        </a>
      </div>
    </nav>
  </div>
</header>

<style>
  [data-state='open'] #hamburger-icon {
    display: none;
  }
  [data-state='open'] #close-icon {
    display: block !important;
  }
  [data-state='closed'] #hamburger-icon {
    display: block !important;
  }
  [data-state='closed'] #close-icon {
    display: none;
  }

  /* Helper for the chevron rotation */
  .rotate-180 {
    transform: rotate(180deg);
  }
</style>

<script>
  function initMenu() {
    const menuBtn = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const servicesToggle = document.getElementById('mobile-services-toggle');
    const servicesList = document.getElementById('mobile-services-list');
    const chevron = document.getElementById('services-chevron');

    if (!menuBtn || !mobileMenu) return;

    // Main Menu Toggle
    menuBtn.onclick = () => {
      const isClosed = menuBtn.getAttribute('data-state') === 'closed';

      if (isClosed) {
        menuBtn.setAttribute('data-state', 'open');
        mobileMenu.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
      } else {
        menuBtn.setAttribute('data-state', 'closed');
        mobileMenu.classList.add('translate-x-full');
        document.body.style.overflow = '';
      }
    };

    // Submenu (Services) Toggle
    if (servicesToggle && servicesList && chevron) {
      servicesToggle.onclick = (e) => {
        e.preventDefault();
        const isHidden = servicesList.classList.contains('hidden');

        if (isHidden) {
          servicesList.classList.remove('hidden');
          servicesList.classList.add('flex');
          chevron.classList.add('rotate-180');
        } else {
          servicesList.classList.add('hidden');
          servicesList.classList.remove('flex');
          chevron.classList.remove('rotate-180');
        }
      };
    }
  }

  // Support for Astro View Transitions and initial load
  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>

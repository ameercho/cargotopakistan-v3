---
import { sanityClient } from "sanity:client";
import { Phone, MessageSquare, ChevronDown, Menu } from 'lucide-react';
import Logo from './Logo.astro';

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const services = await sanityClient.fetch(`*[_type == "service"] | order(title asc)`);
---

<header class="sticky top-0 z-[100] bg-white border-b border-slate-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
    
    <a href="/" class="hover:opacity-90 transition-opacity w-32 md:w-auto">
      <Logo />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      <a href="/" class="font-semibold text-slate-600 hover:text-blue-600">Home</a>
      
      <div class="relative group py-4">
        <button class="font-semibold text-slate-600 group-hover:text-blue-600 flex items-center gap-1">
          Services
          <ChevronDown size={14} />
        </button>
        
        <div class="absolute top-full -left-4 w-60 bg-white border border-slate-100 shadow-xl rounded-xl p-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all">
          {services.map((s) => (
            <a href={`/services/${s.slug.current}`} class="block px-4 py-2 hover:bg-blue-50 rounded-lg font-medium text-slate-700">
              {s.title}
            </a>
          ))}
        </div>
      </div>
      
      <a href="#rates" class="font-semibold text-slate-600 hover:text-blue-600">Rates</a>
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      <a href={`tel:${settings?.phone}`} class="md:hidden p-2.5 bg-blue-50 text-blue-600 rounded-full" aria-label="Call Us">
        <Phone size={20} />
      </a>

      <a href={`https://wa.me/${settings?.whatsappNumber || settings?.ctaValue}`} class="md:hidden p-2.5 bg-green-50 text-green-600 rounded-full" aria-label="WhatsApp Us">
        <MessageSquare size={20} />
      </a>

      <a href={`tel:${settings?.phone}`} class="hidden lg:flex items-center gap-2 font-bold text-slate-900">
        <Phone size={18} className="text-blue-600" />
        {settings?.phone}
      </a>
      
      <a href={`https://wa.me/${settings?.whatsappNumber || settings?.ctaValue}`} class="hidden md:flex bg-green-600 text-white px-6 py-2.5 rounded-lg font-bold items-center gap-2 hover:bg-green-700 transition-colors">
        <MessageSquare size={18} />
        WhatsApp
      </a>

      <button class="md:hidden p-2 text-slate-600" id="mobile-menu-button">
        <Menu size={24} />
      </button>
    </div>
  </div>
</header>
---
import { sanityClient } from 'sanity:client';
import { Phone, MessageSquare, ChevronDown, Menu, X } from 'lucide-react';
import Logo from './Logo.astro';

// Fetching Global Settings including our new Header Menu
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{
  ...,
  headerMenu[]
}`);

// Fetching Services for the dropdown
const services = (await sanityClient.fetch(`*[_type == "service"] | order(order asc)`)) || [];

// Safety check for navLinks
const navLinks = settings?.headerMenu || [];
---

<header class="sticky top-0 z-[100] bg-white border-b border-slate-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="hover:opacity-90 transition-opacity w-32 md:w-auto">
      <Logo />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class="font-semibold text-slate-600 hover:text-blue-600 transition-colors"
          >
            {item.label}
          </a>
        ))
      }

      <div class="relative group py-4">
        <button
          class="font-semibold text-slate-600 group-hover:text-blue-600 flex items-center gap-1"
        >
          Services
          <ChevronDown size={14} />
        </button>

        <div
          class="absolute top-full -left-4 w-60 bg-white border border-slate-100 shadow-xl rounded-xl p-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all"
        >
          {
            services.map((s) => (
              <a
                href={`/services/${s.slug.current}`}
                class="block px-4 py-2 hover:bg-blue-50 rounded-lg font-medium text-slate-700 transition-colors"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      <a
        href={`tel:${settings?.phone}`}
        class="flex items-center justify-center w-10 h-10 md:w-auto md:h-auto rounded-full md:rounded-none bg-blue-50/50 md:bg-transparent text-blue-600 hover:bg-blue-100 transition-colors"
        aria-label="Call Us"
      >
        <Phone size={20} />
        <span class="hidden lg:inline ml-2 font-bold text-slate-900">{settings?.phone}</span>
      </a>

      <a
        href={`https://wa.me/${settings?.whatsappNumber}`}
        class="flex items-center justify-center w-10 h-10 md:w-auto md:px-6 md:py-2.5 rounded-full md:rounded-lg bg-green-50/50 md:bg-green-600 text-green-600 md:text-white hover:bg-green-100 md:hover:bg-green-700 transition-colors md:shadow-lg md:shadow-green-100"
        aria-label="Chat on WhatsApp"
      >
        <MessageSquare size={20} />
        <span class="hidden md:inline ml-2 font-bold">WhatsApp</span>
      </a>

      <button
        class="md:hidden p-2 text-slate-600 relative z-[110] flex items-center justify-center"
        id="mobile-menu-button"
        aria-label="Toggle Menu"
        data-state="closed"
      >
        <div id="hamburger-icon">
          <Menu size={28} />
        </div>
        <div id="close-icon" class="hidden">
          <X size={28} />
        </div>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white z-[105] translate-x-full transition-transform duration-300 md:hidden pt-24 px-6 overflow-y-auto"
  >
    <nav class="flex flex-col gap-6">
      {
        navLinks.map((item) => (
          <a href={item.link} class="text-2xl font-bold text-slate-900 border-b pb-4">
            {item.label}
          </a>
        ))
      }

      <div class="flex flex-col gap-4">
        <p class="text-xs font-black text-blue-600 uppercase tracking-widest">Our Services</p>
        <div class="grid grid-cols-1 gap-3">
          {
            services.map((s) => (
              <a
                href={`/services/${s.slug.current}`}
                class="text-lg font-semibold text-slate-700 pl-2 border-l-2 border-blue-100"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>
  </div>
</header>

<style>
  /* Ensure correct icon visibility based on button state */
  [data-state='open'] #hamburger-icon {
    display: none;
  }
  [data-state='open'] #close-icon {
    display: block !important;
  }
  [data-state='closed'] #hamburger-icon {
    display: block !important;
  }
  [data-state='closed'] #close-icon {
    display: none;
  }
</style>

<script>
  function initMenu() {
    const menuBtn = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');

    if (!menuBtn || !mobileMenu) return;

    menuBtn.replaceWith(menuBtn.cloneNode(true));
    const newBtn = document.getElementById('mobile-menu-button');

    newBtn.addEventListener('click', () => {
      const isClosed = newBtn.getAttribute('data-state') === 'closed';

      if (isClosed) {
        newBtn.setAttribute('data-state', 'open');
        mobileMenu.classList.remove('translate-x-full');
        document.body.style.overflow = 'hidden';
      } else {
        newBtn.setAttribute('data-state', 'closed');
        mobileMenu.classList.add('translate-x-full');
        document.body.style.overflow = '';
      }
    });
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>

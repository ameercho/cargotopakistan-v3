---
import { sanityClient } from 'sanity:client';
import { Phone, MessageSquare, ChevronDown, Menu, X } from 'lucide-react';
import Logo from './Logo.astro';

// Fetch Menu from settings, but Contact from contactChannel (matches FloatingActions)
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]{ headerMenu[] }`);
const contactData = await sanityClient.fetch(`*[_type == "contactChannel" && isActive == true]`);
const services = (await sanityClient.fetch(`*[_type == "service"] | order(order asc)`)) || [];

const navLinks = settings?.headerMenu || [];

// Find the specific channels from the contactData array
const whatsapp = contactData.find((c) => c.platform === 'whatsapp')?.value;
const phone = contactData.find((c) => c.platform === 'phone' || c.platform === 'landline')?.value;
---

<header class="sticky top-0 z-[100] bg-white border-b border-slate-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="hover:opacity-90 transition-opacity w-32 md:w-auto">
      <Logo />
    </a>

    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class="font-semibold text-slate-600 hover:text-blue-600 transition-colors"
          >
            {item.label}
          </a>
        ))
      }

      <div class="relative group py-4">
        <button
          class="font-semibold text-slate-600 group-hover:text-blue-600 flex items-center gap-1"
        >
          Services <ChevronDown size={14} />
        </button>
        <div
          class="absolute top-full -left-4 w-60 bg-white border border-slate-100 shadow-xl rounded-xl p-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all"
        >
          {
            services.map((s) => (
              <a
                href={`/services/${s.slug.current}`}
                class="block px-4 py-2 hover:bg-blue-50 rounded-lg font-medium text-slate-700 transition-colors"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      {
        phone && (
          <a
            href={`tel:${phone}`}
            class="hidden md:flex items-center text-blue-600 hover:text-blue-700 transition-colors"
          >
            <Phone size={20} />
            <span class="ml-2 font-bold text-slate-900">{phone}</span>
          </a>
        )
      }

      {
        whatsapp && (
          <a
            href={`https://wa.me/${whatsapp}`}
            class="hidden md:flex items-center px-6 py-2.5 rounded-lg bg-green-600 text-white hover:bg-green-700 transition-colors shadow-lg shadow-green-100"
          >
            <MessageSquare size={20} />
            <span class="ml-2 font-bold">WhatsApp</span>
          </a>
        )
      }

      <button
        class="md:hidden p-2 text-slate-600 relative z-[110]"
        id="mobile-menu-button"
        data-state="closed"
      >
        <div id="hamburger-icon"><Menu size={28} /></div>
        <div id="close-icon" class="hidden"><X size={28} /></div>
      </button>
    </div>
  </div>

  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white z-[105] translate-x-full transition-transform duration-300 md:hidden pt-24 px-6 overflow-y-auto"
  >
    <nav class="flex flex-col gap-4">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class="text-2xl font-bold text-slate-900 border-b border-slate-50 pb-4"
          >
            {item.label}
          </a>
        ))
      }
      <div class="mt-4 flex flex-col gap-6">
        {
          phone && (
            <a
              href={`tel:${phone}`}
              class="flex items-center gap-3 text-lg font-bold text-slate-900"
            >
              <Phone class="text-blue-600" /> {phone}
            </a>
          )
        }
        {
          whatsapp && (
            <a
              href={`https://wa.me/${whatsapp}`}
              class="flex items-center gap-3 text-lg font-bold text-green-600"
            >
              <MessageSquare /> WhatsApp
            </a>
          )
        }
      </div>
    </nav>
  </div>
</header>

<script>
  function initMenu() {
    const menuBtn = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    if (!menuBtn || !mobileMenu) return;
    menuBtn.onclick = () => {
      const isClosed = menuBtn.getAttribute('data-state') === 'closed';
      menuBtn.setAttribute('data-state', isClosed ? 'open' : 'closed');
      mobileMenu.classList.toggle('translate-x-full');
      document.body.style.overflow = isClosed ? 'hidden' : '';
    };
  }
  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>

---
import { sanityClient } from 'sanity:client';
import { Phone, MessageSquare, ChevronDown, Menu, X } from 'lucide-react';
import Logo from './Logo.astro';

// 1. DIRECT FETCH (Bypasses CDN to ensure fresh URLs and contact data)
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`, {}, { useCdn: false });

const contactData = await sanityClient.fetch(
  `*[_type == "contactChannel" && isActive == true]`,
  {},
  { useCdn: false }
);

const services = await sanityClient.fetch(
  `*[_type == "service"] | order(order asc)`,
  {},
  { useCdn: false }
);

// 2. Navigation Logic
const navLinks =
  settings?.headerMenu?.length > 0
    ? settings.headerMenu
    : [
        { label: 'Home', link: '/' },
        { label: 'About', link: '/about' },
        { label: 'Contact', link: '/contact' },
      ];

// 3. Contact Logic (Priority to contactChannel, Fallback to siteSettings)
const whatsappRaw =
  contactData.find((c) => c.platform === 'whatsapp')?.value || settings?.whatsappNumber;
const phone =
  contactData.find((c) => c.platform === 'phone' || c.platform === 'landline')?.value ||
  settings?.phone;

// Clean WhatsApp for the URL (removes spaces/dashes)
const whatsappLink = whatsappRaw ? whatsappRaw.replace(/\s+/g, '') : '';
---

<header class="sticky top-0 z-[100] bg-white border-b border-slate-100 shadow-sm">
  <div class="max-w-7xl mx-auto px-4 md:px-6 h-16 md:h-20 flex items-center justify-between">
    <a href="/" class="hover:opacity-90 transition-opacity w-32 md:w-auto">
      <Logo />
    </a>

    <!-- Desktop Navigation -->
    <nav class="hidden md:flex items-center gap-8">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class={`font-semibold transition-colors ${item.isButton ? 'px-5 py-2 bg-blue-600 text-white rounded-lg hover:bg-blue-700' : 'text-slate-600 hover:text-blue-600'}`}
          >
            {item.label}
          </a>
        ))
      }

      <!-- Services Dropdown -->
      <div class="relative group py-4">
        <button
          class="font-semibold text-slate-600 group-hover:text-blue-600 flex items-center gap-1"
        >
          Services <ChevronDown size={14} />
        </button>
        <div
          class="absolute top-full -left-4 w-64 bg-white border border-slate-100 shadow-xl rounded-xl p-2 opacity-0 pointer-events-none group-hover:opacity-100 group-hover:pointer-events-auto transition-all"
        >
          {
            services.map((s) => (
              <a
                href={`/${s.slug.current}`}
                class="block px-4 py-2 hover:bg-blue-50 rounded-lg font-medium text-slate-700 transition-colors"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>
    </nav>

    <!-- Right Side Actions -->
    <div class="flex items-center gap-2 md:gap-4">
      {
        phone && (
          <a
            href={`tel:${phone}`}
            class="hidden lg:flex items-center text-blue-600 hover:text-blue-700 transition-colors"
          >
            <Phone size={20} />
            <span class="ml-2 font-bold text-slate-900">{phone}</span>
          </a>
        )
      }

      {
        whatsappLink && (
          <a
            href={`https://wa.me/${whatsappLink}`}
            class="hidden md:flex items-center px-6 py-2.5 rounded-lg bg-green-600 text-white hover:bg-green-700 transition-colors shadow-lg"
          >
            <MessageSquare size={20} />
            <span class="ml-2 font-bold">WhatsApp</span>
          </a>
        )
      }

      <!-- Mobile Toggle -->
      <button
        class="md:hidden p-2 text-slate-600 relative z-[110]"
        id="mobile-menu-button"
        data-state="closed"
      >
        <div id="hamburger-icon"><Menu size={28} /></div>
        <div id="close-icon" class="hidden"><X size={28} /></div>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Overlay -->
  <div
    id="mobile-menu"
    class="fixed inset-0 bg-white z-[105] translate-x-full transition-transform duration-300 md:hidden pt-24 px-6 overflow-y-auto"
  >
    <nav class="flex flex-col gap-2">
      {
        navLinks.map((item) => (
          <a
            href={item.link}
            class="text-2xl font-bold text-slate-900 py-4 border-b border-slate-50"
          >
            {item.label}
          </a>
        ))
      }

      <div class="border-b border-slate-50">
        <button
          id="mobile-services-toggle"
          class="flex items-center justify-between w-full text-2xl font-bold text-slate-900 py-4"
        >
          Services <ChevronDown
            id="services-chevron"
            size={24}
            class="transition-transform duration-200"
          />
        </button>
        <div
          id="mobile-services-list"
          class="hidden flex-col gap-2 pb-4 pl-4 bg-slate-50 rounded-2xl mb-4"
        >
          {
            services.map((s) => (
              <a
                href={`/${s.slug.current}`}
                class="block py-3 text-lg font-semibold text-slate-600"
              >
                {s.title}
              </a>
            ))
          }
        </div>
      </div>

      <!-- Mobile Contact Actions -->
      <div class="mt-8 flex flex-col gap-4">
        {
          phone && (
            <a
              href={`tel:${phone}`}
              class="flex items-center justify-center gap-3 p-4 bg-slate-100 rounded-xl font-bold text-slate-900"
            >
              <Phone size={20} /> Call Now
            </a>
          )
        }
        {
          whatsappLink && (
            <a
              href={`https://wa.me/${whatsappLink}`}
              class="flex items-center justify-center gap-3 p-4 bg-green-600 text-white rounded-xl font-bold"
            >
              <MessageSquare size={20} /> WhatsApp Us
            </a>
          )
        }
      </div>
    </nav>
  </div>
</header>

<script>
  function initMenu() {
    const menuBtn = document.getElementById('mobile-menu-button');
    const mobileMenu = document.getElementById('mobile-menu');
    const hamburgerIcon = document.getElementById('hamburger-icon');
    const closeIcon = document.getElementById('close-icon');
    const servicesToggle = document.getElementById('mobile-services-toggle');
    const servicesList = document.getElementById('mobile-services-list');
    const servicesChevron = document.getElementById('services-chevron');

    if (menuBtn && mobileMenu) {
      menuBtn.onclick = () => {
        const isClosed = menuBtn.getAttribute('data-state') === 'closed';
        menuBtn.setAttribute('data-state', isClosed ? 'open' : 'closed');
        mobileMenu.classList.toggle('translate-x-full');
        hamburgerIcon?.classList.toggle('hidden');
        closeIcon?.classList.toggle('hidden');
        document.body.style.overflow = isClosed ? 'hidden' : '';
      };
    }

    if (servicesToggle && servicesList && servicesChevron) {
      servicesToggle.onclick = () => {
        const isHidden = servicesList.classList.contains('hidden');
        servicesList.classList.toggle('hidden');
        servicesList.classList.toggle('flex');
        servicesChevron.style.transform = isHidden ? 'rotate(180deg)' : 'rotate(0deg)';
      };
    }
  }

  initMenu();
  document.addEventListener('astro:after-swap', initMenu);
</script>

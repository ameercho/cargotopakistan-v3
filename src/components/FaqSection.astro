---
const { faqs = [] } = Astro.props;
import { PortableText } from 'astro-portabletext';
import { ChevronDown } from 'lucide-react';
---

<div class="faq-container space-y-4">
  {
    faqs.map((faq, index) => (
      <div class="faq-item group border border-slate-200 rounded-3xl bg-white overflow-hidden transition-all duration-300 hover:border-blue-400">
        {/* Question Trigger */}
        <button
          class="faq-trigger w-full flex items-center justify-between p-6 text-left focus:outline-none"
          aria-expanded="false"
          data-index={index}
        >
          <span class="text-lg font-bold text-slate-900 group-hover:text-blue-600 transition-colors flex items-start">
            <span class="text-blue-600 mr-3">Q.</span>
            {faq.question}
          </span>
          <div class="chevron-icon text-slate-400 group-hover:text-blue-600 transition-transform duration-300">
            <ChevronDown size={24} />
          </div>
        </button>

        {/* Expandable Content Container */}
        <div class="faq-content hidden px-6 pb-6">
          <div class="pt-2 border-t border-slate-100 mt-2">
            {/* AI-Optimized Atomic Answer */}
            {(faq.atomicAnswer || faq.answer) && (
              <div class="bg-blue-50/50 border-l-4 border-blue-600 p-5 mb-6 rounded-r-2xl">
                <p class="text-slate-700 leading-relaxed italic font-medium">
                  {faq.atomicAnswer || faq.answer}
                </p>
              </div>
            )}

            {/* Detailed Human-Focused Answer */}
            {faq.detailedAnswer && (
              <div class="prose prose-slate prose-blue max-w-none text-slate-600 px-2">
                <PortableText value={faq.detailedAnswer} />
              </div>
            )}
          </div>
        </div>
      </div>
    ))
  }
</div>

<script>
  function setupFaqs() {
    const triggers = document.querySelectorAll('.faq-trigger');

    triggers.forEach((trigger) => {
      trigger.addEventListener('click', () => {
        const item = trigger.closest('.faq-item');
        const content = item.querySelector('.faq-content');
        const chevron = trigger.querySelector('.chevron-icon');
        const isExpanded = trigger.getAttribute('aria-expanded') === 'true';

        // Toggle state
        trigger.setAttribute('aria-expanded', !isExpanded ? 'true' : 'false');
        content.classList.toggle('hidden');

        // Animate Chevron
        if (!isExpanded) {
          chevron.style.transform = 'rotate(180deg)';
          item.classList.add('shadow-xl', 'border-blue-200');
        } else {
          chevron.style.transform = 'rotate(0deg)';
          item.classList.remove('shadow-xl', 'border-blue-200');
        }
      });
    });
  }

  // Run on page load and view transitions
  setupFaqs();
  document.addEventListener('astro:after-swap', setupFaqs);
</script>

<style>
  .faq-content {
    /* Smooth transition for opening - simple toggle for performance */
    animation: slideDown 0.3s ease-out;
  }

  @keyframes slideDown {
    from {
      opacity: 0;
      transform: translateY(-10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>

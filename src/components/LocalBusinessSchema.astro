---
const { settings } = Astro.props;

// EXPERT FIX: We use an array for @type to ensure Google validation
// while keeping the specific LogisticsBusiness classification.
const schema = {
  '@context': 'https://schema.org',
  '@type': ['LocalBusiness', 'LogisticsBusiness'],
  '@id': `${settings?.siteUrl || 'https://cargotopakistan.ae'}/#organization`,
  name: settings?.businessName || 'Cargo To Pakistan',
  legalName: settings?.legalName,
  url: settings?.siteUrl || 'https://cargotopakistan.ae',
  logo: `${settings?.siteUrl || 'https://cargotopakistan.ae'}/favicon.svg`,
  image: settings?.ogImage
    ? settings.ogImage.asset.url
    : `${settings?.siteUrl || 'https://cargotopakistan.ae'}/og-default.jpg`,
  address: {
    '@type': 'PostalAddress',
    streetAddress: settings?.address,
    addressLocality: 'Dubai',
    addressRegion: 'Dubai',
    addressCountry: 'AE',
  },
  geo: settings?.geoCoordinates
    ? {
        '@type': 'GeoCoordinates',
        latitude: settings.geoCoordinates.lat,
        longitude: settings.geoCoordinates.lng,
      }
    : undefined,
  telephone: settings?.phone,
  contactPoint: [
    {
      '@type': 'ContactPoint',
      telephone: settings?.whatsappNumber,
      contactType: 'customer service',
      availableLanguage: ['en', 'ur', 'hi'],
    },
  ],
  openingHoursSpecification: [
    {
      '@type': 'OpeningHoursSpecification',
      dayOfWeek: ['Monday', 'Tuesday', 'Wednesday', 'Thursday', 'Friday', 'Saturday', 'Sunday'],
      opens: '00:00',
      closes: '23:59',
    },
  ],
  sameAs: settings?.socialLinks || [],
  identifier: settings?.tradeLicense,
};
---

<script type="application/ld+json" set:html={JSON.stringify(schema)} />

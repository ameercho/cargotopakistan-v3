---
import { sanityClient } from "sanity:client";
import { MapPin, Phone, Ship } from 'lucide-react';
import Logo from './Logo.astro';

// 1. Fetching data for the footer
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const services = await sanityClient.fetch(`*[_type == "service"] | order(title asc)`);
const serviceAreas = settings?.mainServiceAreas || [];
---

<footer class="bg-slate-900 text-slate-400 py-16 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-4 gap-12">
    
    <div class="space-y-6">
      <div class="brightness-0 invert opacity-90">
        <Logo />
      </div>
      <p class="text-sm leading-relaxed">
        Premium door-to-door cargo services from UAE to Pakistan. Moving your items with safety and speed since 2026.
      </p>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6">Our Services</h4>
      <ul class="space-y-4 text-sm">
        {services.map((s) => (
          <li>
            <a href={`/services/${s.slug.current}`} class="hover:text-blue-400 transition-colors">
              {s.title} to Pakistan
            </a>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6">Service Areas</h4>
      <ul class="grid grid-cols-2 gap-x-4 gap-y-4 text-xs">
        {serviceAreas.map((area) => (
          <li class="flex items-center gap-2">
            <MapPin size={12} className="text-blue-500" />
            <span>Cargo in {area}</span>
          </li>
        ))}
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6">Contact Us</h4>
      <ul class="space-y-4 text-sm">
        <li class="flex items-center gap-3">
          <Phone size={18} className="text-blue-500" />
          <span class="text-white font-bold">{settings?.phone}</span>
        </li>
        <li class="flex items-center gap-3">
          <MapPin size={18} className="text-blue-500" />
          <span>{settings?.address || 'Dubai, UAE'}</span>
        </li>
      </ul>
    </div>
  </div>

  <div class="max-w-7xl mx-auto px-6 mt-16 pt-8 border-t border-slate-800 flex flex-col md:flex-row justify-between items-center gap-4 text-xs">
    <p>© 2026 PakCargo.ae - All Rights Reserved.</p>
    <div class="flex gap-6">
      <a href="/privacy" class="hover:text-white">Privacy</a>
      <a href="/terms" class="hover:text-white">Terms</a>
    </div>
  </div>
</footer>
---
import { sanityClient } from 'sanity:client';
import { MapPin, Phone, MessageSquare, ShieldCheck } from 'lucide-react';
import Logo from './Logo.astro';

const { seoText } = Astro.props;

const settings = await sanityClient.fetch(
  `*[_type == "siteSettings"][0]{ businessName, description, mainServiceAreas, footerMenu[] }`
);
const contactData = await sanityClient.fetch(`*[_type == "contactChannel" && isActive == true]`);
const services = (await sanityClient.fetch(`*[_type == "service"] | order(title asc)`)) || [];

const whatsapp = contactData.find((c) => c.platform === 'whatsapp')?.value;
const phone = contactData.find((c) => c.platform === 'phone' || c.platform === 'landline')?.value;
---

<footer class="bg-slate-900 text-slate-400 pt-20 pb-10 border-t border-slate-800">
  <div class="max-w-7xl mx-auto px-6 grid grid-cols-1 md:grid-cols-2 lg:grid-cols-4 gap-12">
    <div class="space-y-6">
      <div class="brightness-0 invert opacity-90 w-40"><Logo /></div>
      <p class="text-sm">{settings?.description}</p>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 uppercase">Our Services</h4>
      <ul class="space-y-4 text-sm">
        {
          services.map((s) => (
            <li>
              <a href={`/services/${s.slug.current}`} class="hover:text-blue-400 transition-colors">
                {' '}
                {s.title}
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 uppercase">Service Areas</h4>
      <div class="grid grid-cols-2 gap-4 text-xs">
        {
          settings?.mainServiceAreas?.map((area) => (
            <div class="flex items-center gap-2">
              <>
                <MapPin size={12} />
                <span>{area}</span>
              </>
            </div>
          ))
        }
      </div>
    </div>

    <div>
      <h4 class="text-white font-bold mb-6 uppercase">Contact</h4>
      <ul class="space-y-4 text-sm">
        {
          phone && (
            <li class="flex items-start gap-3">
              <>
                <Phone size={18} class="text-blue-500" />
                <p class="text-white font-bold">{phone}</p>
              </>
            </li>
          )
        }
        {
          whatsapp && (
            <li class="flex items-start gap-3">
              <MessageSquare size={18} class="text-green-500" />
              <a href={`https://wa.me/${whatsapp}`} class="hover:text-white font-bold text-white">
                WhatsApp Support
              </a>
            </li>
          )
        }
      </ul>
      <div class="pt-6 mt-6 border-t border-slate-800">
        <p class="text-xs font-bold text-white mb-4 uppercase">Quick Links</p>
        <div class="flex flex-wrap gap-4 text-xs">
          {
            settings?.footerMenu?.map((link) => (
              <a href={link.link} class="hover:text-blue-400">
                {link.label}
              </a>
            ))
          }
        </div>
      </div>
    </div>
  </div>
</footer>

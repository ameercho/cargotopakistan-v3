---
import { urlFor } from '../lib/sanity';
const { globalPartners = [], localPartners = [] } = Astro.props;

const hasPartners = globalPartners.length > 0 || localPartners.length > 0;
---

{
  hasPartners && (
    <section class="py-12 md:py-24 bg-white border-t border-slate-100">
      <div class="max-w-7xl mx-auto px-6 text-center">
        <div class="inline-block px-4 py-1.5 mb-10 text-xs font-bold tracking-widest text-blue-600 uppercase bg-blue-50 rounded-full">
          Our Network
        </div>

        {globalPartners.length > 0 && (
          <div class="mb-16 md:mb-24">
            <h3 class="text-2xl md:text-3xl font-black text-slate-900 mb-3 italic">
              Global Express Partners
            </h3>
            <p class="text-sm md:text-lg text-slate-500 mb-12 max-w-2xl mx-auto font-medium">
              Fast document and parcel services from UAE via premium air express.
            </p>

            <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-12 md:gap-24">
              {globalPartners.map((partner) => (
                <img
                  src={urlFor(partner.logo).width(400).url()}
                  alt={`${partner.name} - Official Global Shipping Partner`}
                  class="h-7 md:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
                />
              ))}
            </div>
          </div>
        )}

        {localPartners.length > 0 && (
          <div>
            <h3 class="text-2xl md:text-3xl font-black text-slate-900 mb-3 italic">
              Pakistan Last-Mile Network
            </h3>
            <p class="text-sm md:text-lg text-slate-500 mb-12 max-w-2xl mx-auto font-medium">
              Nationwide delivery from our Karachi hub to every city and village.
            </p>

            <div class="flex flex-wrap justify-center items-center gap-x-12 gap-y-12 md:gap-24">
              {localPartners.map((partner) => (
                <img
                  src={urlFor(partner.logo).width(400).url()}
                  alt={`${partner.name} - Pakistan Domestic Delivery Partner`}
                  class="h-7 md:h-10 w-auto object-contain grayscale opacity-60 hover:grayscale-0 hover:opacity-100 transition-all duration-500"
                />
              ))}
            </div>
          </div>
        )}
      </div>
    </section>
  )
}

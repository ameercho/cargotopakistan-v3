---
import { sanityClient } from 'sanity:client';
import Layout from '../layouts/Layout.astro';
import PortableText from '../components/PortableText.astro';
import FaqSection from '../components/FaqSection.astro';
import CTA from '../components/CTA.astro'; // Import CTA Component
import { urlFor } from '../lib/sanity';
import { Truck, Globe2, Award, Users, ShieldCheck } from 'lucide-react';

// Fetch settings and the "About" type company page with resolved pageCTA
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const aboutData = await sanityClient.fetch(`
  *[_type == "companyPage" && pageType == "about"][0]{
    ...,
    pageCTA {
      ...,
      links[] {
        ...,
        channelRef->{ value, platform }
      }
    },
    faqs[] { 
      question, 
      atomicAnswer, 
      detailedAnswer 
    }
  }
`);

const iconMap = {
  'Years Experience': Award,
  'Cargo Moved': Truck,
  'Satisfied Clients': Users,
  Destinations: Globe2,
};

const stats = aboutData?.stats || [
  { label: 'Years Experience', value: '15+' },
  { label: 'Cargo Moved', value: '500k+' },
  { label: 'Satisfied Clients', value: '10k+' },
  { label: 'Destinations', value: 'Pakistan-Wide' },
];
---

<Layout
  title={`${aboutData?.seoTitle || 'About Us'} | ${settings?.businessName || 'cargotopakistan.ae'}`}
  description={aboutData?.metaDescription ||
    `Learn why ${settings?.businessName} is the leader in UAE to Pakistan logistics.`}
>
  <main class="bg-white">
    <section class="relative py-24 bg-slate-900 overflow-hidden">
      <div class="absolute inset-0 opacity-20">
        <div class="absolute inset-0 bg-gradient-to-br from-blue-600 to-transparent"></div>
      </div>
      <div class="relative z-10 max-w-6xl mx-auto px-6 text-center">
        <span class="text-blue-400 font-bold uppercase tracking-widest text-sm mb-4 block">
          {aboutData?.heroSubtitle || 'Our Legacy'}
        </span>
        <h1 class="text-4xl md:text-7xl font-black text-white mb-6 leading-tight">
          {aboutData?.heroTitle || 'Connecting the UAE to Pakistan'}
        </h1>
        <p class="text-slate-300 text-lg max-w-3xl mx-auto leading-relaxed">
          {
            aboutData?.heroDescription ||
              `Based in Jebel Ali, we bridge the gap between global trade and Pakistan's growing demand.`
          }
        </p>
      </div>
    </section>

    <section class="max-w-6xl mx-auto px-6 -mt-12 relative z-20">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-4">
        {
          stats.map((stat) => {
            const Icon = iconMap[stat.label] || Award;
            return (
              <div class="bg-white p-8 rounded-3xl shadow-xl border border-slate-100 text-center transform hover:-translate-y-1 transition-all">
                <div class="flex justify-center mb-4 text-blue-600">
                  <Icon size={32} />
                </div>
                <div class="text-3xl font-black text-slate-900 mb-1">{stat.value}</div>
                <div class="text-sm font-medium text-slate-500 uppercase tracking-tighter">
                  {stat.label}
                </div>
              </div>
            );
          })
        }
      </div>
    </section>

    <section class="py-24 max-w-6xl mx-auto px-6">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-16 items-center">
        <div>
          <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-8 italic leading-tight">
            {aboutData?.bodyTitle || 'Managing the Flow of'}
            <span class="text-blue-600 underline ml-2">
              {aboutData?.bodyTitleAccent || 'Pakistan Trade'}
            </span>
          </h2>
          <div class="space-y-6 text-slate-600 text-lg leading-relaxed prose prose-slate">
            {
              aboutData?.content ? (
                <PortableText value={aboutData.content} />
              ) : (
                <p>
                  Operating primarily from Jebel Ali, we specialize in secure sea and air freight.
                </p>
              )
            }
          </div>
        </div>

        <div class="relative">
          <div class="aspect-square bg-slate-200 rounded-[3rem] overflow-hidden shadow-2xl">
            {
              aboutData?.mainImage ? (
                <img
                  src={urlFor(aboutData.mainImage).width(800).url()}
                  alt={aboutData.mainImage?.alt || 'Cargo Operations'}
                  class="w-full h-full object-cover"
                />
              ) : (
                <img
                  src="https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?q=80&w=800"
                  alt="Warehouse operations"
                  class="w-full h-full object-cover"
                />
              )
            }
          </div>
          <div
            class="absolute -bottom-6 -left-6 bg-white p-8 rounded-3xl shadow-xl border border-slate-100 max-w-xs"
          >
            <p class="text-slate-600 text-sm italic font-medium">
              "{aboutData?.quoteText || 'Providing stress-free cargo service.'}"
            </p>
            <p class="mt-4 font-bold text-slate-900">
              — {aboutData?.quoteAuthor || 'Leadership Team'}
            </p>
          </div>
        </div>
      </div>
    </section>

    {
      aboutData?.faqs && aboutData.faqs.length > 0 && (
        <section class="py-24 bg-slate-50">
          <div class="max-w-4xl mx-auto px-6">
            <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-12 text-center">
              Common Questions
            </h2>
            <FaqSection faqs={aboutData.faqs} />
          </div>
        </section>
      )
    }

    {/* Dynamic CTA Section replaces the hardcoded one */}
    {aboutData?.pageCTA && <CTA {...aboutData.pageCTA} />}
  </main>
</Layout>

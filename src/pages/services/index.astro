---
import { sanityClient } from 'sanity:client';
import Layout from '../../layouts/Layout.astro';
import { Ship, Plane, FileText, Home, Package, Truck, MapPin } from 'lucide-react';

const services = await sanityClient.fetch(`*[_type == "service"] | order(order asc, title asc)`);
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

const baseUrl = settings?.siteUrl || 'https://cargotopakistan.ae';

const iconMap = {
  ship: Ship,
  plane: Plane,
  'file-text': FileText,
  home: Home,
  package: Package,
  truck: Truck,
};

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: `${settings?.businessName || 'Cargo'} Services Catalog`,
  description: 'Comprehensive list of door-to-door cargo services from UAE to Pakistan.',
  itemListElement: services.map((service, index) => ({
    '@type': 'ListItem',
    position: index + 1,
    url: `${baseUrl}/services/${service.slug.current}`,
    name: service.title,
  })),
};

const breadcrumbSchema = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: baseUrl },
    { '@type': 'ListItem', position: 2, name: 'Services', item: `${baseUrl}/services` },
  ],
};
---

<Layout
  title={`Cargo Services to Pakistan | ${settings?.title || 'Professional Logistics'}`}
  description={settings?.description}
>
  <main class="py-16 bg-slate-50">
    <div class="max-w-6xl mx-auto px-6">
      <nav class="flex items-center gap-2 text-sm text-slate-400 mb-8">
        <a href="/" class="hover:text-blue-600 transition-colors">Home</a>
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"
          ><path d="M9 5l7 7-7 7"></path></svg
        >
        <span class="text-slate-900 font-medium">Services</span>
      </nav>

      <header class="mb-16">
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-6 tracking-tight">
          Our <span class="text-blue-600">Cargo Services</span> to Pakistan
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed max-w-3xl">
          We provide the most comprehensive <strong>cargo services from UAE to Pakistan</strong>.
          Whether you need fast air freight or budget-friendly sea cargo, we offer guaranteed <strong
            >door to door cargo pickup</strong
          > across the Emirates.
        </p>
      </header>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8 mb-20">
        {
          services.map((service) => {
            const IconComponent = iconMap[service.icon] || Package;
            return (
              <div class="bg-white p-8 rounded-[2rem] border border-slate-100 shadow-sm hover:shadow-xl transition-all group flex flex-col">
                <div class="mb-6 inline-block p-4 bg-blue-50 text-blue-600 rounded-2xl group-hover:bg-blue-600 group-hover:text-white transition-colors self-start">
                  <IconComponent size={32} />
                </div>
                <h2 class="text-2xl font-bold text-slate-900 mb-4">{service.title}</h2>
                <p class="text-slate-600 mb-6 leading-relaxed line-clamp-3">
                  {service.description}
                </p>

                <div class="mt-auto space-y-4">
                  {service.startingPrice && (
                    <div class="py-2 px-4 bg-slate-50 rounded-lg inline-block text-sm font-semibold text-slate-700">
                      Starting from <span class="text-blue-600">AED {service.startingPrice}</span>
                    </div>
                  )}

                  <a
                    href={`/services/${service.slug.current}`}
                    class="flex items-center justify-between w-full py-4 px-6 bg-slate-900 text-white font-bold rounded-xl hover:bg-blue-600 transition-colors"
                  >
                    View Details
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path
                        stroke-linecap="round"
                        stroke-linejoin="round"
                        stroke-width="2"
                        d="M14 5l7 7m0 0l-7 7m7-7H3"
                      />
                    </svg>
                  </a>
                </div>
              </div>
            );
          })
        }
      </div>

      <section class="bg-white rounded-[2.5rem] p-10 md:p-16 border border-slate-100 shadow-sm">
        <div class="flex items-center gap-4 mb-8">
          <div class="p-3 bg-green-100 text-green-600 rounded-full">
            <MapPin size={24} />
          </div>
          <h2 class="text-3xl font-bold text-slate-900">Areas We Serve in UAE</h2>
        </div>

        <p class="text-slate-600 mb-10 text-lg">
          We offer free door-to-door cargo pickup for all shipments from Dubai and neighboring
          emirates. Our logistics network covers:
        </p>

        <div class="grid grid-cols-2 md:grid-cols-4 gap-4">
          {
            settings?.mainServiceAreas?.map((area) => (
              <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-xl border border-slate-100 font-bold text-slate-800">
                <div class="w-2 h-2 bg-blue-600 rounded-full" />
                {area}
              </div>
            ))
          }
        </div>
      </section>
    </div>
  </main>

  <script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />
  <script type="application/ld+json" set:html={JSON.stringify(breadcrumbSchema)} />
</Layout>

---
import { sanityClient } from 'sanity:client';
import Layout from '../../layouts/Layout.astro';
import { urlFor } from '../../lib/sanity';
import PortableText from '../../components/PortableText.astro';
import FaqSection from '../../components/FaqSection.astro';
import { Ship, Plane, FileText, Home, Package, Truck, MapPin, CheckCircle2 } from 'lucide-react';
import RatesTable from '../../components/RatesTable.astro';

export async function getStaticPaths() {
  const services = await sanityClient.fetch(`*[_type == "service"]`);
  return services.map((service) => ({
    params: { slug: service.slug.current },
    props: { service },
  }));
}

const { slug } = Astro.params;

// Fetch Contact Channels for correct numbers
const contactData = await sanityClient.fetch(`*[_type == "contactChannel" && isActive == true]`);
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

const service = await sanityClient.fetch(
  `*[_type == "service" && slug.current == $slug][0]{
    ...,
    rateTable,
    faqs[] {
      question,
      answer
    }
  }`,
  { slug }
);

const whatsapp = contactData.find((c) => c.platform === 'whatsapp')?.value;
const phone = contactData.find((c) => c.platform === 'phone' || c.platform === 'landline')?.value;

const iconMap = {
  ship: Ship,
  plane: Plane,
  'file-text': FileText,
  home: Home,
  package: Package,
  truck: Truck,
};
const IconComponent = iconMap[service.icon] || Package;

const baseUrl = settings?.siteUrl || 'https://cargotopakistan.ae';

const faqSchemaItems =
  service.faqs?.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: faq.answer || 'Contact us for detailed information.',
    },
  })) || [];

const combinedSchema = {
  '@context': 'https://schema.org',
  '@graph': [
    {
      '@type': 'Service',
      name: service.title,
      description: service.metaDescription || service.description,
      serviceType: service.serviceType || 'FreightTransportService',
      provider: { '@id': `${baseUrl}/#organization` },
      areaServed: service.serviceableAreas?.map((area) => ({ '@type': 'Place', name: area })) || [
        { '@type': 'Country', name: 'United Arab Emirates' },
      ],
      offers: {
        '@type': 'Offer',
        priceCurrency: 'AED',
        price: service.startingPrice || '0',
      },
    },
    ...(faqSchemaItems.length > 0
      ? [
          {
            '@type': 'FAQPage',
            mainEntity: faqSchemaItems,
          },
        ]
      : []),
    {
      '@type': 'BreadcrumbList',
      itemListElement: [
        { '@type': 'ListItem', position: 1, name: 'Home', item: baseUrl },
        {
          '@type': 'ListItem',
          position: 2,
          name: 'Services',
          item: `${baseUrl}/services`,
        },
        {
          '@type': 'ListItem',
          position: 3,
          name: service.title,
          item: `${baseUrl}/services/${service.slug.current}`,
        },
      ],
    },
  ],
};
---

<Layout
  title={service.seoTitle || `${service.title} | ${settings?.title || 'Cargo to Pakistan'}`}
  description={service.metaDescription || service.description}
  ogImage={service.mainImage}
>
  <script type="application/ld+json" set:html={JSON.stringify(combinedSchema)} slot="head" />

  <main class="bg-slate-50 min-h-screen">
    <section
      class="relative min-h-[600px] md:min-h-[700px] flex items-center overflow-hidden bg-slate-900 pt-20 pb-32 md:pb-48"
    >
      {
        service.mainImage && (
          <img
            src={urlFor(service.mainImage).width(1600).url()}
            alt={service.title}
            class="absolute inset-0 w-full h-full object-cover opacity-40"
          />
        )
      }
      <div class="absolute inset-0 bg-gradient-to-t from-slate-900 via-slate-900/60 to-transparent">
      </div>

      <div class="relative z-10 max-w-6xl mx-auto px-6 w-full">
        <nav class="text-blue-400 text-sm mb-6 flex items-center gap-2 font-medium">
          <a href="/" class="hover:text-white transition-colors text-xs md:text-sm">Home</a>
          <span class="text-xs md:text-sm">/</span>
          <a href="/services" class="hover:text-white transition-colors text-xs md:text-sm"
            >Services</a
          >
          <span class="text-xs md:text-sm">/</span>
          <span class="text-white text-xs md:text-sm truncate max-w-[150px] md:max-w-none"
            >{service.title}</span
          >
        </nav>

        <div
          class="inline-flex items-center gap-3 px-4 py-2 bg-blue-600/20 border border-blue-500/30 rounded-full text-blue-300 text-xs md:text-sm font-bold mb-6 backdrop-blur-md"
        >
          <IconComponent size={18} />
          <span>Professional Logistics</span>
        </div>

        <h1
          class="text-3xl md:text-7xl font-black text-white mb-6 tracking-tight max-w-4xl leading-[1.1]"
        >
          {service.heroTitle || service.title}
        </h1>

        {
          service.heroSubtitle ? (
            <p class="text-lg md:text-2xl text-slate-300 max-w-2xl font-medium leading-relaxed">
              {service.heroSubtitle}
            </p>
          ) : (
            service.startingPrice && (
              <p class="text-xl md:text-2xl text-blue-400 font-bold">
                Rates starting from AED {service.startingPrice}
              </p>
            )
          )
        }
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-4 md:px-6 -mt-12 md:-mt-24 relative z-20 pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
          <div
            class="bg-white p-6 md:p-12 rounded-[2rem] md:rounded-[2.5rem] shadow-xl shadow-slate-200/50 border border-slate-100"
          >
            <h2 class="text-2xl md:text-3xl font-bold text-slate-900 mb-6 italic">
              Reliable {service.title} Solution
            </h2>
            <div class="prose prose-slate prose-sm md:prose-lg max-w-none mb-10">
              <PortableText value={service.details} />
            </div>

            <RatesTable rates={service.rateTable} serviceTitle={service.title} />
          </div>

          {
            service.serviceableAreas && service.serviceableAreas.length > 0 && (
              <div class="bg-blue-600 rounded-[2rem] md:rounded-[2.5rem] p-6 md:p-12 text-white shadow-2xl">
                <div class="flex items-center gap-4 mb-8">
                  <div class="p-3 bg-white/10 rounded-2xl backdrop-blur-md text-white">
                    <MapPin size={28} />
                  </div>
                  <div>
                    <h3 class="text-xl md:text-2xl font-bold">Fast Pickup Locations</h3>
                    <p class="text-blue-100 text-sm md:text-base">
                      Direct {service.title} pickup from your doorstep
                    </p>
                  </div>
                </div>

                <div class="grid grid-cols-2 sm:grid-cols-3 gap-3">
                  {service.serviceableAreas.map((area) => (
                    <div class="flex items-center gap-2 p-3 bg-white/10 rounded-xl border border-white/10 hover:bg-white/20 transition-colors">
                      <CheckCircle2 size={14} class="text-blue-300" />
                      <span class="text-xs md:text-sm font-semibold">{area}</span>
                    </div>
                  ))}
                </div>
              </div>
            )
          }

          {
            service.faqs && service.faqs.length > 0 && (
              <div class="bg-white p-6 md:p-12 rounded-[2rem] md:rounded-[2.5rem] shadow-sm border border-slate-100">
                <h3 class="text-2xl md:text-3xl font-bold text-slate-900 mb-10">
                  Frequently Asked Questions
                </h3>
                <FaqSection faqs={service.faqs} />
              </div>
            )
          }
        </div>

        <div class="space-y-6">
          <div
            class="bg-white p-6 md:p-8 rounded-[2rem] shadow-sm border border-slate-100 sticky top-24"
          >
            <h3 class="text-xl font-bold text-slate-900 mb-6">Service Benefits</h3>
            <ul class="space-y-4 mb-8">
              {
                service.keyFeatures?.map((feature) => (
                  <li class="flex items-start gap-3">
                    <div class="mt-1 bg-green-100 text-green-600 rounded-full p-1 flex-shrink-0">
                      <CheckCircle2 size={16} />
                    </div>
                    <span class="text-slate-600 text-sm md:text-base font-medium">{feature}</span>
                  </li>
                ))
              }
            </ul>

            <div class="space-y-4">
              {
                whatsapp && (
                  <a
                    href={`https://wa.me/${whatsapp}`}
                    class="flex items-center justify-center gap-3 w-full py-4 bg-green-600 text-white font-bold rounded-2xl hover:bg-green-700 transition-all shadow-lg shadow-green-200"
                  >
                    <span class="text-lg">WhatsApp Quote</span>
                  </a>
                )
              }
              {
                phone && (
                  <a
                    href={`tel:${phone}`}
                    class="flex items-center justify-center gap-3 w-full py-4 bg-blue-600 text-white font-bold rounded-2xl hover:bg-blue-700 transition-all shadow-lg shadow-blue-200"
                  >
                    <span>Call Specialist</span>
                  </a>
                )
              }
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

---
import { sanityClient } from "sanity:client";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { urlFor } from "../../lib/sanity";
import { PortableText } from "astro-portabletext";
import FaqSection from "../../components/FaqSection.astro"; // Import our new component

// 1. Generate paths for all services
export async function getStaticPaths() {
  const services = await sanityClient.fetch(`*[_type == "service"]`);
  
  return services.map((service) => ({
    params: { slug: service.slug.current },
    props: { service },
  }));
}

const { slug } = Astro.params;

// 2. Fetch the service with the NEW FAQ fields included
const service = await sanityClient.fetch(`
  *[_type == "service" && slug.current == $slug][0]{
    ...,
    faqs[] {
      question,
      atomicAnswer,
      detailedAnswer,
      lastReviewed
    }
  }
`, { slug });

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

// 3. GEO-Optimized FAQ Schema for Search Engines
// We now build this dynamically from your Sanity entries
const faqSchema = service.faqs ? {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": service.faqs.map((faq) => ({
    "@type": "Question",
    "name": faq.question,
    "acceptedAnswer": {
      "@type": "Answer",
      "text": faq.atomicAnswer
    }
  }))
} : null;
---

<BaseLayout 
  title={service.seoTitle || `${service.title} | PakCargo.ae`}
  description={service.metaDescription || service.description}
>
  <main class="py-16 bg-white">
    <article class="max-w-4xl mx-auto px-6">
      
      <nav class="text-sm text-slate-400 mb-8 flex items-center gap-2">
        <a href="/" class="hover:text-blue-600 transition-colors">Home</a> 
        <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"/></svg>
        <span class="text-slate-900 font-medium">{service.title}</span>
      </nav>

      <header class="mb-12 border-b border-slate-100 pb-12">
        <h1 class="text-4xl md:text-6xl font-extrabold text-slate-900 mb-6 tracking-tight">
          {service.seoTitle || service.title}
        </h1>
        <p class="text-xl text-slate-600 leading-relaxed max-w-2xl">
          {service.description}
        </p>
      </header>

      {service.keyFeatures && (
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-16">
          {service.keyFeatures.map((feature) => (
            <div class="flex items-center p-5 bg-blue-50/50 rounded-xl border border-blue-100 group hover:border-blue-300 transition-colors">
              <div class="bg-blue-600 rounded-full p-1 mr-4">
                <svg class="w-3 h-3 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="3" d="M5 13l4 4L19 7" />
                </svg>
              </div>
              <span class="font-bold text-slate-800">{feature}</span>
            </div>
          ))}
        </div>
      )}

      <div class="prose prose-lg prose-slate max-w-none 
        prose-headings:font-bold prose-headings:text-slate-900 
        prose-p:text-slate-600 prose-strong:text-blue-600">
        <PortableText value={service.details} />
      </div>

      {service.faqs && service.faqs.length > 0 && (
        <div class="mt-20 border-t border-slate-100 pt-16">
          <FaqSection faqs={service.faqs} />
        </div>
      )}

      <div class="mt-20 p-8 md:p-12 bg-slate-900 rounded-[2rem] text-white relative overflow-hidden shadow-2xl">
        <div class="relative z-10">
          <h2 class="text-3xl md:text-4xl font-bold mb-4">Ready to Ship {service.title}?</h2>
          <p class="text-slate-400 mb-10 text-lg max-w-xl">
            Get the best rates for <strong>door-to-door cargo to Pakistan</strong>. Our team is ready to assist you in Dubai.
          </p>
          <div class="flex flex-col sm:flex-row gap-4">
            <a 
              href={`https://wa.me/${settings?.ctaValue}`} 
              class="px-8 py-4 bg-green-600 text-white font-bold rounded-xl hover:bg-green-700 transition-all text-center flex items-center justify-center gap-2"
            >
              <svg class="w-6 h-6" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/></svg>
              WhatsApp Now
            </a>
            <a 
              href={`tel:${settings?.phone}`} 
              class="px-8 py-4 bg-blue-600 text-white font-bold rounded-xl hover:bg-blue-700 transition-all text-center"
            >
              Call Specialist
            </a>
          </div>
        </div>
        <div class="absolute -right-20 -top-20 w-80 h-80 bg-blue-600/20 rounded-full blur-[100px]"></div>
      </div>

    </article>
  </main>

  {faqSchema && <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />}
</BaseLayout>
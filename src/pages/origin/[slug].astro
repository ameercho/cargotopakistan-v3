---
import { sanityClient } from 'sanity:client';
import Layout from '../../layouts/Layout.astro';
import { MapPin, Clock, Truck, PhoneCall, ShieldCheck } from 'lucide-react';

export async function getStaticPaths() {
  // Fetch only Origin types from our new 'location' schema
  const origins = await sanityClient.fetch(`*[_type == "location" && type == "origin"]`);

  return origins.map((loc) => ({
    params: { slug: loc.slug.current },
    props: { loc },
  }));
}

const { loc } = Astro.props;
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

// Fetch top 3 services to display as local options
const services = await sanityClient.fetch(`*[_type == "service"] | order(order asc) [0...3]`);

// Optimized SEO Schema for UAE Local Business
const originSchema = {
  '@context': 'https://schema.org',
  '@type': 'LocalBusiness',
  name: `${settings?.businessName || 'Cargo to Pakistan'} - ${loc.title} Branch`,
  image: settings?.logo,
  telePhone: settings?.phone,
  url: `${settings?.siteUrl}/origin/${loc.slug.current}`,
  address: {
    '@type': 'PostalAddress',
    addressLocality: loc.title,
    addressRegion: loc.province,
    addressCountry: 'AE',
  },
  description:
    loc.metaDescription ||
    `Professional door-to-door cargo services from ${loc.title} to all cities in Pakistan.`,
  areaServed: [
    { '@type': 'City', name: loc.title },
    { '@type': 'Country', name: 'Pakistan' },
  ],
};
---

<Layout
  title={loc.seoTitle || `Cargo to Pakistan from ${loc.title} | Door-to-Door Service`}
  description={loc.metaDescription ||
    `Best rates for shipping from ${loc.title} to Pakistan. Daily pickups in ${loc.subAreas?.join(', ')}. Sea and Air cargo specialists.`}
>
  <script type="application/ld+json" set:html={JSON.stringify(originSchema)} slot="head" />

  <main>
    {/* HERO SECTION */}
    <section class="bg-slate-900 py-24 relative overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <div
          class="inline-flex items-center gap-2 px-3 py-1 bg-blue-500/20 border border-blue-500/30 rounded-full text-blue-300 text-xs font-bold mb-6"
        >
          <MapPin size={14} />
          <span>UAE Logistics Hub: {loc.title}</span>
        </div>
        <h1 class="text-4xl md:text-7xl font-black text-white mb-6 leading-tight">
          Reliable Cargo from <span class="text-blue-500">{loc.title}</span>
          <br />to Pakistan
        </h1>
        <p class="text-slate-400 text-xl max-w-2xl leading-relaxed">
          {
            loc.heroSubtitle ||
              `Daily door-to-door pickups across all major areas of ${loc.title}. We ensure safe delivery from your UAE doorstep to any city in Pakistan.`
          }
        </p>
      </div>
    </section>

    {/* LOCAL SUB-AREAS SECTION */}
    <section class="py-12 bg-white border-b border-slate-100">
      <div class="max-w-6xl mx-auto px-6">
        <h2 class="text-sm font-bold text-slate-400 uppercase tracking-widest mb-6 text-center">
          Standard Pickup Locations in {loc.title}
        </h2>
        <div class="flex flex-wrap justify-center gap-3">
          {
            loc.subAreas?.map((area) => (
              <span class="px-5 py-2 bg-slate-50 border border-slate-200 rounded-full text-slate-700 font-medium text-sm">
                {area}
              </span>
            ))
          }
          <span
            class="px-5 py-2 bg-blue-50 border border-blue-100 rounded-full text-blue-600 font-bold text-sm"
          >
            + All Other {loc.title} Zones
          </span>
        </div>
      </div>
    </section>

    {/* SERVICES GRID */}
    <section class="py-24 max-w-6xl mx-auto px-6">
      <div class="flex flex-col md:flex-row justify-between items-end mb-12 gap-6">
        <div class="max-w-2xl">
          <h2 class="text-3xl md:text-5xl font-black text-slate-900 mb-4 italic">
            Available Services in {loc.title}
          </h2>
          <p class="text-slate-600 text-lg">
            Choose the best shipping method for your needs. We handle all UAE customs documentation
            and Pakistan clearance.
          </p>
        </div>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
        {
          services.map((service) => (
            <div class="group bg-white rounded-[2.5rem] border border-slate-200 p-8 hover:shadow-2xl hover:border-blue-500 transition-all">
              <div class="mb-6 p-4 bg-slate-50 rounded-2xl w-fit group-hover:bg-blue-600 group-hover:text-white transition-colors">
                <Truck size={24} />
              </div>
              <h3 class="text-2xl font-bold text-slate-900 mb-4">{service.title}</h3>
              <p class="text-slate-600 text-sm mb-8 line-clamp-3">{service.description}</p>
              <a
                href={`/services/${service.slug.current}`}
                class="flex items-center gap-2 font-bold text-blue-600 hover:gap-4 transition-all"
              >
                View Rates <span class="text-xl">→</span>
              </a>
            </div>
          ))
        }
      </div>
    </section>

    {/* LOCAL TRUST POINTS */}
    <section class="py-20 bg-slate-50 rounded-[4rem] mx-4 mb-20 px-6">
      <div class="max-w-4xl mx-auto text-center">
        <h2 class="text-3xl font-black text-slate-900 mb-12">
          Why {settings?.businessName} in {loc.title}?
        </h2>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-8 text-left">
          <div class="flex gap-4">
            <div
              class="shrink-0 w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-blue-600"
            >
              <Clock size={20} />
            </div>
            <div>
              <h4 class="font-bold text-slate-900">Swift {loc.title} Pickup</h4>
              <p class="text-sm text-slate-600">
                Call before 2:00 PM for same-day cargo collection across {loc.province}.
              </p>
            </div>
          </div>
          <div class="flex gap-4">
            <div
              class="shrink-0 w-12 h-12 bg-white rounded-2xl shadow-sm flex items-center justify-center text-blue-600"
            >
              <ShieldCheck size={20} />
            </div>
            <div>
              <h4 class="font-bold text-slate-900">Secure Packaging</h4>
              <p class="text-sm text-slate-600">
                Professional industrial packing available for electronics and fragile items.
              </p>
            </div>
          </div>
        </div>
      </div>
    </section>

    {/* CALL TO ACTION */}
    <section class="max-w-6xl mx-auto px-6 pb-24 text-center">
      <div class="bg-blue-600 rounded-[3rem] p-12 text-white shadow-2xl shadow-blue-200">
        <h2 class="text-3xl md:text-5xl font-black mb-6">Ship from {loc.title} Today</h2>
        <p class="text-blue-100 mb-10 text-lg">
          Contact our {loc.title} operations team for exclusive weight-based rates.
        </p>
        <div class="flex flex-col sm:flex-row gap-4 justify-center">
          <a
            href={`tel:${settings?.phone}`}
            class="bg-white text-blue-600 px-8 py-4 rounded-2xl font-black flex items-center justify-center gap-2 hover:bg-blue-50 transition-colors"
          >
            <PhoneCall size={18} /> Call Specialist
          </a>
          <a
            href={`https://wa.me/${settings?.whatsappNumber}?text=Hi, I want to ship from ${loc.title} to Pakistan.`}
            class="bg-green-500 text-white px-8 py-4 rounded-2xl font-black flex items-center justify-center gap-2 hover:bg-green-600 transition-colors"
          >
            WhatsApp Quote
          </a>
        </div>
      </div>
    </section>
  </main>
</Layout>

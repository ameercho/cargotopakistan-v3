---
import { sanityClient } from 'sanity:client';
import Layout from '../../layouts/Layout.astro';
import { MapPin, Clock, ShieldCheck, Box, CheckCircle2 } from 'lucide-react';

export async function getStaticPaths() {
  const locations = await sanityClient.fetch(`*[_type == "location" && type == "destination"]`);
  return locations.map((loc) => ({
    params: { slug: loc.slug.current },
    props: { loc },
  }));
}

const { loc } = Astro.props;
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);

// Professional Logistics Schema
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Service',
  name: `Cargo Delivery to ${loc.title}`,
  description: loc.metaDescription,
  provider: {
    '@type': 'LocalBusiness',
    name: settings?.businessName,
    image: settings?.logo,
  },
  areaServed: {
    '@type': 'City',
    name: loc.title,
    containedInPlace: { '@type': 'Country', name: 'Pakistan' },
  },
  hasOfferCatalog: {
    '@type': 'OfferCatalog',
    name: 'Shipping Services',
    itemListElement: [
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Sea Cargo' } },
      { '@type': 'Offer', itemOffered: { '@type': 'Service', name: 'Air Cargo' } },
    ],
  },
};
---

<Layout title={loc.seoTitle} description={loc.metaDescription}>
  <script type="application/ld+json" set:html={JSON.stringify(schema)} slot="head" />

  <main class="bg-slate-50">
    <section class="bg-blue-900 py-24 relative overflow-hidden">
      <div class="max-w-6xl mx-auto px-6 relative z-10">
        <span
          class="inline-block px-4 py-1 bg-blue-500/30 rounded-full text-blue-200 text-sm font-bold mb-6"
        >
          Destination Hub: {loc.province}
        </span>
        <h1 class="text-4xl md:text-7xl font-black text-white mb-6">
          Cargo to <span class="text-blue-400 italic">{loc.title}</span>
        </h1>
        <p class="text-blue-100 text-lg max-w-2xl leading-relaxed">
          {loc.heroSubtitle}
        </p>
      </div>
    </section>

    <div class="max-w-6xl mx-auto px-6 -mt-12 pb-24">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-8">
          <div class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-xl border border-slate-100">
            <h2 class="text-3xl font-black text-slate-900 mb-8 italic">Reliable Timelines</h2>
            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
              <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                <div class="flex items-center gap-3 mb-4 text-blue-600">
                  <Clock size={24} />
                  <span class="font-black uppercase tracking-widest text-xs">Estimated Transit</span
                  >
                </div>
                <p class="text-2xl font-bold text-slate-900">{loc.deliveryTimeline}</p>
              </div>
              <div class="p-6 bg-slate-50 rounded-3xl border border-slate-100">
                <div class="flex items-center gap-3 mb-4 text-green-600">
                  <ShieldCheck size={24} />
                  <span class="font-black uppercase tracking-widest text-xs">Security</span>
                </div>
                <p class="text-2xl font-bold text-slate-900">Door-to-Door Guaranteed</p>
              </div>
            </div>
          </div>

          <div class="bg-white p-8 md:p-12 rounded-[2.5rem] shadow-sm border border-slate-100">
            <h2 class="text-3xl font-black text-slate-900 mb-6 italic">
              Areas Covered in {loc.title}
            </h2>
            <div class="grid grid-cols-2 sm:grid-cols-3 gap-4">
              {
                loc.subAreas?.map((area) => (
                  <div class="flex items-center gap-3 p-4 bg-slate-50 rounded-2xl border border-slate-100">
                    <CheckCircle2 size={18} class="text-blue-500 shrink-0" />
                    <span class="font-bold text-slate-800 text-sm">{area}</span>
                  </div>
                ))
              }
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div
            class="bg-white p-8 rounded-[2.5rem] shadow-sm border border-slate-100 sticky top-24"
          >
            <Box size={32} class="text-blue-600 mb-6" />
            <h3 class="text-2xl font-bold text-slate-900 mb-4">Request Rates</h3>
            <div class="space-y-3">
              <a
                href={`https://wa.me/${settings?.whatsappNumber}`}
                class="flex items-center justify-center w-full py-4 bg-green-600 text-white font-bold rounded-2xl hover:bg-green-700 transition-all"
              >
                WhatsApp Quote
              </a>
              <a
                href={`tel:${settings?.phone}`}
                class="flex items-center justify-center w-full py-4 bg-slate-900 text-white font-bold rounded-2xl hover:bg-black transition-all"
              >
                Call Support
              </a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

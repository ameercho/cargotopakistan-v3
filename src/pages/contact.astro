---
import { sanityClient } from 'sanity:client';
import Layout from '../layouts/Layout.astro';
import { Mail, Phone, MapPin, Clock, MessageSquare, ShieldCheck } from 'lucide-react';

const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
// Fetch specifically the 'contact' type company page
const contactData = await sanityClient.fetch(
  `*[_type == "companyPage" && pageType == "contact"][0]`
);

const contactSchema = {
  '@context': 'https://schema.org',
  '@type': 'ContactPage',
  mainEntity: {
    '@type': 'LocalBusiness',
    name: settings?.businessName || 'cargotopakistan.ae',
    address: {
      '@type': 'PostalAddress',
      streetAddress: settings?.address,
      addressLocality: 'Dubai',
      addressCountry: 'AE',
    },
    telephone: settings?.phone,
  },
};
---

<Layout
  title={`${contactData?.seoTitle || 'Contact Us'} | ${settings?.businessName || 'cargotopakistan.ae'}`}
  description={contactData?.metaDescription || 'Contact our specialists for cargo to Pakistan.'}
>
  <script type="application/ld+json" set:html={JSON.stringify(contactSchema)} slot="head" />

  <main class="bg-slate-50">
    <section class="bg-slate-900 pt-32 pb-20 px-6 text-center">
      <h1 class="text-4xl md:text-6xl font-black text-white mb-4">
        {contactData?.heroTitle || 'Get a Fast Quote'}
      </h1>
      <p class="text-blue-200 text-lg max-w-2xl mx-auto">
        {contactData?.heroSubtitle || 'Our specialists are ready 24/7.'}
      </p>
    </section>

    <div class="max-w-6xl mx-auto px-6 -mt-10 pb-20">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
        <div class="lg:col-span-2 space-y-6">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <a
              href={`tel:${settings?.phone}`}
              class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:border-blue-500 transition-all group"
            >
              <div
                class="p-4 bg-blue-50 rounded-2xl w-fit mb-6 text-blue-600 group-hover:bg-blue-600 group-hover:text-white transition-colors"
              >
                <Phone size={24} />
              </div>
              <h3 class="text-xl font-bold text-slate-900 mb-2">Main Office</h3>
              <span class="text-blue-600 font-bold text-lg">{settings?.phone}</span>
            </a>

            {
              contactData?.additionalContacts?.map((contact) => (
                <a
                  href={`tel:${contact.number}`}
                  class="bg-white p-8 rounded-3xl shadow-sm border border-slate-100 hover:border-blue-500 transition-all group"
                >
                  <div class="p-4 bg-slate-50 rounded-2xl w-fit mb-6 text-slate-600 group-hover:bg-blue-600 group-hover:text-white transition-colors">
                    <Phone size={24} />
                  </div>
                  <h3 class="text-xl font-bold text-slate-900 mb-2">{contact.label}</h3>
                  <span class="text-blue-600 font-bold text-lg">{contact.number}</span>
                </a>
              ))
            }
          </div>

          <div class="bg-white p-10 rounded-[2.5rem] shadow-sm border border-slate-100">
            <div class="flex gap-6 mb-8">
              <div class="shrink-0 p-4 bg-slate-100 rounded-2xl h-fit"><MapPin /></div>
              <div>
                <h4 class="font-bold text-lg">Jebel Ali Warehouse</h4>
                <p class="text-slate-600">{settings?.address}</p>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </main>
</Layout>

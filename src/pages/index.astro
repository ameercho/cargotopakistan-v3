---
import BaseLayout from "../layouts/BaseLayout.astro";
import BlogSection from "../components/BlogSection.astro";
import { sanityClient } from "sanity:client";
import { urlFor } from "../lib/sanity";
import PriceGrid from "../components/PriceGrid.astro";
import ServiceSection from "../components/ServiceSection.astro";
import Hero from "../components/Hero.astro";
import WhyChooseUs from "../components/WhyChooseUs.astro";
import PartnerLogos from "../components/PartnerLogos.astro";

// 1. Fetch data
const settings = await sanityClient.fetch(`*[_type == "siteSettings"][0]`);
const services = await sanityClient.fetch(`*[_type == "service"] | order(_createdAt asc)`);
const rates = await sanityClient.fetch(`*[_type == "rateCard"] | order(pricePerKg asc)`);

// Fetch Partners
const globalPartners = await sanityClient.fetch(`*[_type == "partner" && type == "global"]`);
const localPartners = await sanityClient.fetch(`*[_type == "partner" && type == "local"]`);

const trustData = await sanityClient.fetch(`*[_type == "trustPoints"][0]`);

// 2. Technical SEO Schema (Linked to 1,900+ Volume Keywords)
const businessSchema = {
  "@context": "https://schema.org",
  "@type": "LogisticsCompany",
  "name": "PakCargo.ae",
  "url": "https://pakcargo.ae",
  "logo": "https://pakcargo.ae/favicon.svg",
  "image": settings?.ogImage ? urlFor(settings.ogImage).width(1200).url() : "https://pakcargo.ae/og-image.jpg",
  "telephone": settings?.phone || "+971XXXXXXXXX",
  "priceRange": "$$",
  "description": settings?.description || "Reliable pakistan cargo and pak cargo services. Door-to-door delivery from Dubai to all cities in Pakistan.",
  "address": {
    "@type": "PostalAddress",
    "streetAddress": settings?.address || "Dubai, UAE",
    "addressLocality": "Dubai",
    "addressRegion": "Dubai",
    "addressCountry": "AE"
  },
  "geo": {
    "@type": "GeoCoordinates",
    "latitude": "25.2048",
    "longitude": "55.2708"
  },
  "openingHoursSpecification": [
    {
      "@type": "OpeningHoursSpecification",
      "dayOfWeek": ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday"],
      "opens": "09:00",
      "closes": "21:00"
    }
  ],
  "knowsAbout": [
    "pakistan cargo", 
    "pak cargo", 
    "cargo to pakistan", 
    "air cargo to pakistan", 
    "cargo dubai to pakistan", 
    "door to door cargo"
  ],
  "areaServed": [
    { "@type": "Country", "name": "United Arab Emirates" },
    { "@type": "Country", "name": "Pakistan" }
  ],
  "memberOf": [
    { "@type": "Organization", "name": "TCS Express Network" },
    { "@type": "Organization", "name": "Leopards Courier Service Network" }
  ]
};
---

<BaseLayout 
  title={settings?.title || "Pakistan Cargo from Dubai | Best Pak Cargo Service - PakCargo.ae"}
  description={settings?.description || "Leading pakistan cargo service from Dubai. We offer air and sea pak cargo to pakistan with secure door-to-door delivery."}
>
  <Hero />

  <main>
    <ServiceSection services={services} />
    
    <PartnerLogos globalPartners={globalPartners} localPartners={localPartners} />
    {trustData && <WhyChooseUs data={trustData} />}

    <section id="rates" class="py-10"> <PriceGrid rates={rates} />

      <BlogSection />
    </section>

    <section class="py-20 bg-slate-900 text-white">
      <div class="max-w-4xl mx-auto px-6 text-center">
        <h2 class="text-3xl md:text-4xl font-bold mb-6">Ready to Ship with the Best Pak Cargo Service?</h2>
        <p class="text-slate-400 text-lg mb-10 max-w-2xl mx-auto">
          Get a fast quote for <strong>door-to-door cargo to pakistan</strong>. 
          Contact our Dubai team directly via WhatsApp or Phone for the best rates.
        </p>

        <div class="flex flex-col sm:flex-row justify-center items-center gap-4">
          <a 
            href={`https://wa.me/${settings?.ctaValue}`} 
            class="w-full sm:w-auto inline-flex justify-center items-center px-10 py-4 bg-green-600 hover:bg-green-700 text-white font-bold rounded-lg transition-all text-lg shadow-lg shadow-green-900/20"
          >
            <svg class="w-6 h-6 mr-2" fill="currentColor" viewBox="0 0 24 24"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01